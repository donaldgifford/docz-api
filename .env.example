# docz-api local development environment.
#
# Copy to .env and fill in the GitHub/auth values; `just run` reads the
# process environment. Every value here is a DEV-ONLY placeholder that lines
# up with compose.yaml — never reuse any of these in a real deployment.

# Postgres (compose service: postgres)
DATABASE_URL=postgres://docz:secret@localhost:5432/docz_api?sslmode=disable

# Redis — ingest job queue + session store (compose service: redis)
REDIS_URL=redis://localhost:6379/0

# Meilisearch (compose service: meilisearch)
MEILI_HOST=http://localhost:7700
MEILI_API_KEY=masterKey

# GitHub App (ingestion) — replace with your dev app's real values.
# GITHUB_APP_PRIVATE_KEY may be a PEM file path or the PEM body itself.
GITHUB_APP_ID=000000
GITHUB_APP_PRIVATE_KEY=./secrets/docz-app.pem
GITHUB_WEBHOOK_SECRET=replace-me
# GITHUB_API_BASE=https://api.github.com   # override for GitHub Enterprise

# Site auth providers (comma-separated: github, okta, keycloak).
AUTH_PROVIDERS=github
SESSION_SECRET=replace-me-dev-session-secret
# Public base URL of this service; each provider's redirect_uri is
# <AUTH_REDIRECT_BASE>/auth/callback. Use https:// in real deployments so
# session cookies are marked Secure.
AUTH_REDIRECT_BASE=http://localhost:8080

# GitHub OAuth (site login) — required when github is an enabled provider.
GITHUB_OAUTH_CLIENT_ID=replace-me
GITHUB_OAUTH_CLIENT_SECRET=replace-me

# Okta (OIDC) — required only when okta is in AUTH_PROVIDERS.
# OKTA_ISSUER=https://acme.okta.com/oauth2/default
# OKTA_CLIENT_ID=replace-me
# OKTA_CLIENT_SECRET=replace-me

# Keycloak (OIDC) — required only when keycloak is in AUTH_PROVIDERS.
# KEYCLOAK_ISSUER=https://kc.acme.com/realms/acme
# KEYCLOAK_CLIENT_ID=replace-me
# KEYCLOAK_CLIENT_SECRET=replace-me

# Session / ingestion tuning (defaults shown).
# SESSION_TTL=720h
# INGEST_DEBOUNCE=5s

# Server + logging (defaults shown).
# HTTP_ADDR=:8080
# LOG_LEVEL=info
# LOG_FORMAT=text

# Observability (OQ 8; defaults shown). Tracing is a no-op unless an OTLP/HTTP
# collector endpoint (host:port, plaintext) is set — leave it empty for a
# homelab install without a collector. /metrics is served unless disabled.
# OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4318
# OTEL_SERVICE_NAME=docz-api
# OTEL_SAMPLE_RATE=1.0
# METRICS_ENABLED=true
