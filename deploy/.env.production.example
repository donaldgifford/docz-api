# docz-api production configuration template.
#
# Copy to deploy/.env.production (gitignored) and fill in real values from your
# secret manager. deploy/compose.yaml loads this as the service's env store.
#
# DATABASE_URL, REDIS_URL, MEILI_HOST, HTTP_ADDR, and GITHUB_APP_PRIVATE_KEY are
# set by deploy/compose.yaml (service-name networking + the mounted key secret),
# so they are intentionally omitted here.

# --- shared credentials referenced by compose interpolation ---
# POSTGRES_PASSWORD is used both for the postgres container and the service DSN.
POSTGRES_PASSWORD=change-me-postgres
# MEILI_API_KEY is the master key; it must match what the service uses.
MEILI_API_KEY=change-me-meili-master-key

# --- GitHub App (ingestion) ---
GITHUB_APP_ID=000000
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret
# GITHUB_API_BASE=https://api.github.com   # override for GitHub Enterprise

# --- site auth ---
AUTH_PROVIDERS=github
SESSION_SECRET=change-me-session-secret
AUTH_REDIRECT_BASE=https://docz-api.example.com
GITHUB_OAUTH_CLIENT_ID=change-me
GITHUB_OAUTH_CLIENT_SECRET=change-me
# OKTA_ISSUER=https://acme.okta.com/oauth2/default
# OKTA_CLIENT_ID=change-me
# OKTA_CLIENT_SECRET=change-me
# KEYCLOAK_ISSUER=https://kc.example.com/realms/acme
# KEYCLOAK_CLIENT_ID=change-me
# KEYCLOAK_CLIENT_SECRET=change-me

# --- tuning + observability (defaults shown) ---
# SESSION_TTL=720h
# INGEST_DEBOUNCE=5s
# LOG_LEVEL=info
# LOG_FORMAT=json
# OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4318
# OTEL_SERVICE_NAME=docz-api
# OTEL_SAMPLE_RATE=1.0
# METRICS_ENABLED=true
