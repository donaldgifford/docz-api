# docz-api LOCAL ENVIRONMENT configuration template (`just local-up`).
#
# Copy to deploy/.env.local (gitignored) and fill in your DEV GitHub App
# values. deploy/compose.local.yaml loads this as the containerized service's
# env store — same mechanism as production, dev-friendly values.
#
# DATABASE_URL, REDIS_URL, MEILI_HOST, HTTP_ADDR, and GITHUB_APP_PRIVATE_KEY
# are set by compose.local.yaml (service-name networking + the mounted key at
# deploy/secrets/github-app.pem), so they are intentionally omitted here.

# --- shared credentials referenced by compose interpolation ---
POSTGRES_PASSWORD=secret
MEILI_API_KEY=masterKey

# --- GitHub App (ingestion; use your DEV app) ---
GITHUB_APP_ID=000000
GITHUB_WEBHOOK_SECRET=replace-me-webhook-secret
# GITHUB_API_BASE=https://api.github.com   # override for GitHub Enterprise

# --- site auth ---
# For local dev, reuse the same GitHub App for OAuth login (callback URL
# http://localhost:8080/auth/callback + client secret + email permission —
# see deploy/README.md). The browser reaches the service on localhost:8080,
# so the redirect base stays local even though webhooks arrive via ngrok.
AUTH_PROVIDERS=github
SESSION_SECRET=replace-me-dev-session-secret
AUTH_REDIRECT_BASE=http://localhost:8080
GITHUB_OAUTH_CLIENT_ID=replace-me
GITHUB_OAUTH_CLIENT_SECRET=replace-me

# --- ngrok webhook tunnel ---
# Token: https://dashboard.ngrok.com. Set NGROK_ARGS=--domain=<name>.ngrok-free.app
# (one free static domain per account) so the GitHub App's webhook URL
# survives restarts.
NGROK_AUTHTOKEN=replace-me
NGROK_ARGS=

# --- tuning + observability (defaults shown) ---
# SESSION_TTL=720h
# INGEST_DEBOUNCE=5s
LOG_LEVEL=debug
LOG_FORMAT=text
# OTEL_EXPORTER_OTLP_ENDPOINT=
# METRICS_ENABLED=true
