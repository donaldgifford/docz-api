  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Requests per second by matched route template. Route labels come from the docz-api chi route pattern (never expanded path values).",
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (route) (rate(docz_api_http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Request rate (by route)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Latency quantiles from the docz_api_http_request_duration_seconds histogram.",
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(docz_api_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(docz_api_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(docz_api_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "C"
        }
      ],
      "title": "Latency (p50 / p95 / p99, by route)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "4xx and 5xx error rates. 5xx is the alertable tier.",
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (route) (rate(docz_api_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx {{route}}",
          "refId": "A"
        },
        {
          "expr": "sum by (route) (rate(docz_api_http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx {{route}}",
          "refId": "B"
        }
      ],
      "title": "Error rate (5xx / 4xx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Ingest job completion rate by reason and outcome.",
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (reason, status) (rate(docz_api_ingest_jobs_total[5m]))",
          "legendFormat": "{{reason}} {{status}}",
          "refId": "A"
        }
      ],
      "title": "Ingest jobs (rate by reason / status)",
